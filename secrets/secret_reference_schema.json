{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentOps Secret Reference Record",
  "type": "object",
  "required": [
    "secret_ref",
    "tenant_id",
    "secret_type",
    "sensitivity",
    "material_status"
  ],
  "properties": {
    "secret_ref": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "secret_type": {
      "type": "string"
    },
    "sensitivity": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "allowed_identity_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_environments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "material_status": {
      "const": "not_stored_reference_only"
    }
  }
}
