{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentOps Connector Adapter Contract",
  "type": "object",
  "required": [
    "adapter_id",
    "connector_id",
    "display_name",
    "implementation_status",
    "live_execution_enabled",
    "operations"
  ],
  "properties": {
    "adapter_id": {
      "type": "string"
    },
    "connector_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "implementation_status": {
      "enum": [
        "contract_only",
        "dry_run_adapter",
        "live_candidate",
        "live_enabled"
      ]
    },
    "live_execution_enabled": {
      "type": "boolean"
    },
    "allowed_tenants": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_identity_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_secret_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
