{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentOps Dry-Run Connector Result",
  "type": "object",
  "required": [
    "run_id",
    "adapter_id",
    "operation_id",
    "decision",
    "allowed",
    "simulated_result"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "adapter_id": {
      "type": "string"
    },
    "operation_id": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "dry_run_executed",
        "blocked_pending_approval",
        "blocked"
      ]
    },
    "allowed": {
      "type": "boolean"
    },
    "simulated_result": {
      "type": "object"
    }
  }
}
