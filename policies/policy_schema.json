{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Open Enterprise AgentOps Mesh Policy Pack",
  "type": "object",
  "required": [
    "policy_pack_id",
    "version",
    "policies"
  ],
  "properties": {
    "policy_pack_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "policies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "policy_id",
          "name",
          "category",
          "severity",
          "decision",
          "rationale"
        ],
        "properties": {
          "policy_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "decision": {
            "enum": [
              "allow",
              "allow_with_controls",
              "require_approval",
              "deny"
            ]
          },
          "conditions": {
            "type": "object"
          },
          "required_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    }
  }
}