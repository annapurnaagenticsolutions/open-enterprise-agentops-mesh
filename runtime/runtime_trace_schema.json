{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runtime Trace",
  "type": "object",
  "required": [
    "request_id",
    "agent_id",
    "execution_decision",
    "steps"
  ],
  "properties": {
    "request_id": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "execution_decision": {
      "type": "string"
    },
    "provider_id": {
      "type": "string"
    },
    "model_id": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
