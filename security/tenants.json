{
  "version": "1.1.0",
  "tenants": [
    {
      "tenant_id": "tenant-demo-enterprise",
      "display_name": "Demo Enterprise Tenant",
      "status": "active",
      "allowed_domains": [
        "procurement",
        "it_support",
        "hr_policy",
        "customer_support",
        "documentation_intelligence",
        "platform"
      ],
      "allowed_environments": [
        "sandbox",
        "pilot",
        "production"
      ],
      "data_residency": "configurable",
      "isolation_mode": "logical_local_json",
      "max_autonomy_level": 4,
      "allowed_risk_levels": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ],
      "required_controls": [
        "tenant_scoped_registry",
        "tenant_scoped_evidence",
        "trace_tenant_id",
        "least_privilege_role_mapping"
