    {
      "tenant_id": "tenant-regulated-finance",
      "display_name": "Regulated Finance Tenant Example",
      "status": "restricted",
      "allowed_domains": [
        "procurement",
        "documentation_intelligence"
      ],
      "allowed_environments": [
        "sandbox",
        "pilot"
      ],
      "data_residency": "strict_regional",
      "isolation_mode": "dedicated_runtime_recommended",
      "max_autonomy_level": 2,
      "allowed_risk_levels": [
        "Low",
        "Medium"
      ],
      "required_controls": [
        "dedicated_kms",
        "private_model_gateway",
        "human_approval_required",
        "audit_export",
        "sensitive_data_redaction"
